{
  "manifest_version": 3,
  "name": "NodeMind VTON Bridge",
  "version": "3.1",
  "description": "Bridge extension for AI Studio Virtual Stylist Engine",
  "permissions": [
    "scripting",
    "activeTab",
    "tabs",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "https://baibanaro-virtual-stylist-server.hf.space/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true,
      "match_origin_as_fallback": true,
      "run_at": "document_idle"
    }
  ]
}
